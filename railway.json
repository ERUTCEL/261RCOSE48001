{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn unity_bridge.server:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "cron": [
    {
      "schedule": "0 3 * * *",
      "command": "curl -X POST https://memorix-api-production.up.railway.app/api/admin/update-ratings"
    }
  ]
}
